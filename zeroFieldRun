# find and save important directories
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export FOAMTPD_DIR="$HOME/OpenFOAM/threePhaseDensityFoam2D_KM/"

#run blockMesh in case file
#cd $SCRIPT_DIR
#blockMesh
#echo "blockMesh complete"

#replace 0 folder with base fields
cd $SCRIPT_DIR
rm -r 0
cd $FOAMTPD_DIR
cp -r base_fields_dimensionless $SCRIPT_DIR/0
echo "Replaced 0 folder with base fields"

#update threePhaseDensityFoam2D with new createFields.H template
cd $FOAMTPD_DIR
#rm createFields.H
cp Templates/cylindrical_rmi/s031225_KAS4_supp.H createFields.H
echo "Copied selected template into createFields.H"

#wmake threePhaseDensityFoam2D to apply changes
cd $FOAMTPD_DIR
wclean
wmake
echo "Solver constructed with selected field template"

#run first time step on single core to ensure correct field setting
cd $SCRIPT_DIR
sed -i 's/^\([[:space:]]*endTime[[:space:]]*\).*/\11e-10;/' system/controlDict
sed -i 's/^\([[:space:]]*writeInterval[[:space:]]*\).*/\11e-10;/' system/controlDict
threePhaseDensityFoam2D

#now update controlDict to run entire case
cd $SCRIPT_DIR
sed -i 's/^\([[:space:]]*endTime[[:space:]]*\).*/\11e-5;/' system/controlDict
sed -i 's/^\([[:space:]]*writeInterval[[:space:]]*\).*/\176e-9;/' system/controlDict
