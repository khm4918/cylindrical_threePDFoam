FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs ("libROUNDSchemes.so");

application     blastFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         1e-5;

deltaT          1e-10;

writeControl    adjustableRunTime;

writeInterval   176e-9;

cycleWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   12;

runTimeModifiable true;

adjustTimeStep  no;

maxCo           0.5;

maxDeltaT       1e-5;

